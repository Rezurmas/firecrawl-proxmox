# =============================================================================
# Firecrawl .env — szablon konfiguracji dla self-hosted
# =============================================================================
# Instrukcja: Skopiuj ten plik jako .env i uzupełnij zmienne oznaczone ⚠️
#              cp .env.example .env && nano .env
# =============================================================================

# ===== WYMAGANE =====
# Liczba workerów na kolejkę (dostosuj do liczby rdzeni CPU)
NUM_WORKERS_PER_QUEUE=8
PORT=3002
HOST=0.0.0.0

# Wyłączamy autentykację Supabase (niedostępna w self-hosted)
USE_DB_AUTHENTICATION=false

# ===== ⚠️ LLM / AI (WYMAGANE do /extract i JSON format) =====
# DeepSeek API (OpenAI-kompatybilny endpoint)
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-TWÓJ_KLUCZ_DEEPSEEK_API
MODEL_NAME=deepseek-chat
# DeepSeek nie oferuje modelu embeddingowego — zostaw puste
# MODEL_EMBEDDING_NAME=

# Alternatywnie: OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-TWÓJ_KLUCZ_OPENAI
# MODEL_NAME=gpt-4o
# MODEL_EMBEDDING_NAME=text-embedding-3-small

# Alternatywnie: lokalne Ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434/api
# MODEL_NAME=llama3.1:8b
# MODEL_EMBEDDING_NAME=nomic-embed-text

# ===== ⚠️ BAZA DANYCH =====
# Te same wartości muszą być w docker-compose.yaml
POSTGRES_USER=firecrawl
POSTGRES_PASSWORD=ZMIEŃ_NA_SILNE_HASŁO_MIN_32_ZNAKI
POSTGRES_DB=firecrawl
POSTGRES_HOST=nuq-postgres
POSTGRES_PORT=5432

# ===== ⚠️ BEZPIECZEŃSTWO =====
# Ustaw silny, losowy klucz! Chroni dostęp do panelu Bull Queue.
# Minimum 32 znaki (install.sh generuje automatycznie)
BULL_AUTH_KEY=ZMIEŃ_NA_LOSOWY_KLUCZ_MIN_32_ZNAKI

# ===== REDIS (auto-konfiguracja, zwykle nie trzeba zmieniać) =====
# REDIS_URL=redis://redis:6379
# REDIS_RATE_LIMIT_URL=redis://redis:6379

# ===== PLAYWRIGHT (auto-konfiguracja) =====
# PLAYWRIGHT_MICROSERVICE_URL=http://playwright-service:3000/scrape

# ===== WYDAJNOŚĆ =====
# Liczba równoczesnych requestów crawla
CRAWL_CONCURRENT_REQUESTS=10

# Maksymalna liczba równoczesnych zadań crawla
MAX_CONCURRENT_JOBS=5

# Rozmiar puli przeglądarek Playwright
BROWSER_POOL_SIZE=5

# Progi wykorzystania zasobów (0.0-1.0)
# Worker odrzuci nowe zadania gdy CPU/RAM przekroczy te wartości
MAX_CPU=0.8
MAX_RAM=0.8

# ===== PROXY (opcjonalnie — zalecane dla produkcji) =====
# PROXY_SERVER=http://twoj.proxy.com:8080
# PROXY_USERNAME=uzytkownik
# PROXY_PASSWORD=haslo
# BLOCK_MEDIA=true

# ===== SEARXNG (opcjonalnie — alternatywa dla Google Search) =====
# SEARXNG_ENDPOINT=http://twoj-searxng:8080
# SEARXNG_ENGINES=google,bing,duckduckgo
# SEARXNG_CATEGORIES=general

# ===== WEBHOOKI (opcjonalnie) =====
# SELF_HOSTED_WEBHOOK_URL=https://twoj-webhook.example.com/firecrawl
# ALLOW_LOCAL_WEBHOOKS=true

# ===== SUPABASE (NIEDOSTĘPNE w self-hosted) =====
# Zostaw puste. Błędy w logach o Supabase są normalne — ignoruj.
# SUPABASE_ANON_TOKEN=
# SUPABASE_URL=
# SUPABASE_SERVICE_TOKEN=

# ===== POZOSTAŁE (zwykle nie trzeba zmieniać) =====
# TEST_API_KEY=
# LLAMAPARSE_API_KEY=
# SLACK_WEBHOOK_URL=
LOGGING_LEVEL=INFO
# SCRAPING_BEE_API_KEY=
# FIRE_ENGINE_BETA_URL=
# SEARCHAPI_API_KEY=
# SEARCHAPI_ENGINE=google

